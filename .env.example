# Admin-Passwort fuer den geschuetzten Bereich
# Standard: "Admin" — bitte direkt nach dem ersten Login in der Admin-UI ändern
ADMIN_PASSWORD=Admin

# Geheimer Schluessel fuer JWT-Token-Signierung
# Fuer Produktion neu generieren: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
JWT_SECRET=1874c058332dd7b2c43b6c0ad02bf5fc3a8bc7746ecfee25ae8266e1c7edbc4a

# Port des Servers
PORT=3001

# Verschlüsselungsschlüssel für AES-256-GCM (empfohlen, min. 32 Zeichen)
# Fuer Produktion neu generieren: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
ENCRYPTION_KEY=3a3f8195e17aaf686ce7bef48cccc46eb6fd0a794981c5989b36973a36d11bed
