# Admin-Passwort fuer den geschuetzten Bereich
# Standard: "Admin" — bitte direkt nach dem ersten Login in der Admin-UI ändern
ADMIN_PASSWORD=Admin

# Geheimer Schluessel fuer JWT-Token-Signierung (langen zufaelligen String verwenden)
JWT_SECRET=Bitte_JWT_SECRET_ändern

# Port des Servers
PORT=3001

# Verschlüsselungsschlüssel für AES-256-GCM (empfohlen, min. 32 Zeichen)
ENCRYPTION_KEY=Bitte_ENCRYPTION_KEY_ändern
