# Admin-Passwort fuer den geschuetzten Bereich
ADMIN_PASSWORD=bitte-aendern

# Geheimer Schluessel fuer JWT-Token-Signierung (langen zufaelligen String verwenden)
JWT_SECRET=bitte-durch-langen-zufaelligen-string-ersetzen

# Port des Servers
PORT=3001

# Verschlüsselungsschlüssel (optional, empfohlen wenn Dateiverschlüsselung genutzt wird)
# Wenn nicht gesetzt, wird JWT_SECRET als Basis verwendet
# Mindestens 32 zufällige Zeichen empfohlen
ENCRYPTION_KEY=

# GitHub Personal Access Token (nur fuer den Docker Build benoetigt)
# Erstellen unter: https://github.com/settings/tokens
# Benoetigt: read-only Zugriff auf "Contents" (fuer private Repos)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
